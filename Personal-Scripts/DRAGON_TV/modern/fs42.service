[Unit]
Description=FieldStation42 Field Player
After=ffmpeg.service

[Service]
Type=simple
WorkingDirectory=/home/tv/FieldStation42
Environment="DISPLAY=:2"
ExecStartPre=/bin/bash -c 'if [ ! -f /tmp/fs42-started ]; then sleep 5; touch /tmp/fs42-started; fi'
ExecStart=/home/tv/FieldStation42/env/bin/python3 field_player.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
